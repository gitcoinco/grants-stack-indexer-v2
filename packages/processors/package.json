{
    "name": "@grants-stack-indexer/processors",
    "version": "0.0.1",
    "private": true,
    "description": "",
    "license": "MIT",
    "author": "Wonderland",
    "type": "module",
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "directories": {
        "src": "src"
    },
    "files": [
        "dist/*",
        "package.json",
        "!**/*.tsbuildinfo"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "check-types": "tsc --noEmit -p ./tsconfig.json",
        "clean": "rm -rf dist/",
        "format": "prettier --check \"{src,test}/**/*.{js,ts,json}\"",
        "format:fix": "prettier --write \"{src,test}/**/*.{js,ts,json}\"",
        "lint": "eslint \"{src,test}/**/*.{js,ts,json}\"",
        "lint:fix": "pnpm lint --fix",
        "test": "vitest run --config vitest.config.ts --passWithNoTests",
        "test:cov": "vitest run --config vitest.config.ts --coverage"
    },
    "dependencies": {
        "@grants-stack-indexer/chain-providers": "workspace:*",
        "@grants-stack-indexer/metadata": "workspace:*",
        "@grants-stack-indexer/pricing": "workspace:*",
        "@grants-stack-indexer/repository": "workspace:*",
        "@grants-stack-indexer/shared": "workspace:*",
        "statuses-bitmap": "github:gitcoinco/statuses-bitmap#f123d7778e42e16adb98fff2b2ba18c0fee57227",
        "viem": "2.21.19",
        "zod": "3.23.8"
    }
}
